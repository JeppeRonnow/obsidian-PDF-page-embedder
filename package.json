{
	"name": "obsidian-pdf-page-embedder",
	"version": "1.2.6",
	"description": "Quickly embed all pages of a PDF as individual page references with a custom, fast PDF renderer.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [
		"obsidian",
		"pdf",
		"embed",
		"pages"
	],
	"author": "Jeppe Ronnow",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^16.11.6",
		"@typescript-eslint/eslint-plugin": "^8.59.2",
		"@typescript-eslint/parser": "^8.59.2",
		"builtin-modules": "3.3.0",
		"esbuild": "0.17.3",
		"eslint": "^8.57.1",
		"eslint-plugin-obsidian": "^2.31.0",
		"eslint-plugin-obsidianmd": "^0.2.9",
		"obsidian": "latest",
		"tslib": "2.4.0",
		"typescript": "4.7.4"
	},
	"dependencies": {
		"pdf-lib": "^1.17.1",
		"pdfjs-dist": "^3.11.174"
	}
}
